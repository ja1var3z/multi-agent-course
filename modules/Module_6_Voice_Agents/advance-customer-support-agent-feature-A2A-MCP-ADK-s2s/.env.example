# Use the Google AI Studio API key path. Leave GOOGLE_GENAI_USE_VERTEXAI UNSET
# (do NOT set it to 1) — setting it forces the Vertex path and breaks the AI Studio key.
PYTHONWARNINGS=ignore

# Google ADK API Key (required for Gemini model)
GOOGLE_API_KEY=

# Mem0 API Key (required for persistent memory)
MEM0_API_KEY=

# Google Cloud Project (required for DLP masking and Secret Manager)
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=

# Google Model Armor (optional - for input sanitization via Model Armor API)
MODEL_ARMOR_TEMPLATE_ID=

# Ports & database are HARD-CODED in this project's code (s2s profile: web 8001,
# toolbox 5001, A2A 11002/11003, its OWN Postgres 5433, Phoenix 6007) — nothing to set
# here, and DISTINCT from cascade so both apps run at once.
# (Do NOT add PGUSER/PGPASSWORD/PGDATABASE: psql reads PGUSER automatically and it
#  would break `run.sh setup`, which must create that role before it exists.)

# Voice / speech-to-speech (used by ./run.sh voice). Requires a Gemini Live model
# your GOOGLE_API_KEY can access. Defaults shown -- override only if needed.
# VOICE_MODEL=gemini-3.1-flash-live-preview
# VOICE_NAME=Kore

# Voice cost estimate — per-1M-token prices (USD) for the Live model, by modality.
# These are PLACEHOLDERS: verify the current numbers for your VOICE_MODEL on
# Google's pricing page (audio tokens cost far more than text). Shown in the UI
# under each answer as an estimate.
# PRICE_TEXT_IN_PER_1M=0.75
# PRICE_AUDIO_IN_PER_1M=3.00
# PRICE_TEXT_OUT_PER_1M=4.50
# PRICE_AUDIO_OUT_PER_1M=12.00

# A2A Security Judge cost is ESTIMATED (gemini-2.5-flash: $0.30 in / $2.50 out per 1M).
# JUDGE_PRICE_IN_PER_1M=0.30
# JUDGE_PRICE_OUT_PER_1M=2.50
# JUDGE_OVERHEAD_TOKENS=260

# Observability
# TELEMETRY=true launches Arize Phoenix (http://localhost:6007 — see PHOENIX_PORT above;
#   cascade uses 6006) and traces every turn (typed + spoken). TELEMETRY=false is fully
#   off (no Phoenix, zero overhead). Keep it off for benchmarking; turn it on to demo
#   observability. Requires the phoenix / openinference / opentelemetry packages when true.
TELEMETRY=true
