GOOGLE_GENAI_USE_VERTEXAI=1

# Google ADK API Key (required for Gemini model)
GOOGLE_API_KEY=

# Mem0 API Key (required for persistent memory)
MEM0_API_KEY=

# Google Cloud Project (required for DLP masking and Secret Manager)
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=

# Google Model Armor (optional - for input sanitization via Model Armor API)
MODEL_ARMOR_TEMPLATE_ID=

# Ports & database are HARD-CODED in this project's code (cascade profile: web 8000,
# toolbox 5000, A2A 10002/10003, Postgres 5432, Phoenix 6006) — nothing to set here.
# (Do NOT add PGUSER/PGPASSWORD/PGDATABASE: psql reads PGUSER automatically and it
#  would break `run.sh setup`, which must create that role before it exists.)

# Voice / pipeline behavior
# MASK=true runs the A2A Data Masker on every reply (needs GOOGLE_CLOUD_PROJECT to
#   actually mask; otherwise it's a ~5s no-op). MASK=false skips it entirely.
MASK=true
# AGENT_RESPONSE_STREAM=true makes voice speak each sentence as it's generated.
# Only applies when MASK=false (streaming and full-reply masking are mutually exclusive).
AGENT_RESPONSE_STREAM=false

# Observability
# TELEMETRY=true launches Arize Phoenix (http://localhost:6006 — see PHOENIX_PORT above;
#   s2s uses 6007) and traces every turn (text + voice). TELEMETRY=false is fully off (no
#   Phoenix, zero overhead). Keep it off for benchmarking; turn it on to demo
#   observability. Requires the phoenix / openinference / opentelemetry packages when true.
TELEMETRY=true


